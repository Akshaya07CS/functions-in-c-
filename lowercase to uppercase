#include <stdio.h>

char lower_to_upper(char ch);

char lower_to_upper(char ch) {
    char upper;
    if (ch >= 'a' && ch <= 'z') {
        upper = ch - 32;
    } else {
        upper = ch;
    }
    return upper;
}

int main() {
    char ch, res;
    printf("Enter a character:");
    scanf("%c", &ch);
    res = lower_to_upper(ch);
    printf("Uppercase: %c", res);
    return 0;
}
