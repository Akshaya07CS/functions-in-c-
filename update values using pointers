#include <stdio.h>
void update_values(int *x, int *y);
void update_values(int *x, int *y) {
    *x = *x * 2;
    *y = *y * 3;
    printf("Inside function: x=%d, y=%d\n", *x, *y);
}
int main() {
    int a, b;
    printf("Enter two numbers:\n");
    scanf("%d %d", &a, &b);

    update_values(&a, &b);
    printf("In main: a=%d, b=%d\n", a, b);
    return 0;
}
