#include <stdio.h>
#include <math.h>

int is_prime(int n);

int is_prime(int n) {
    int i, f = 1;
    if (n <= 1)
        f = 0;
    else {
        for (i = 2; i <= sqrt(n); i++) {
            if (n % i == 0) {
                f = 0;
                break;
            }
        }
    }
    return f;
}

int main() {
    int num, res;
    printf("Enter the number:");
    scanf("%d", &num);

    res = is_prime(num);
    if (res == 1)
        printf("%d is a prime number.\n", num);
    else
        printf("%d is not a prime number.\n", num);

    return 0;
}
